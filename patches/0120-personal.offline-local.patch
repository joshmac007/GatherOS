-  const dismiss = () => {
-    rememberDismissed(current.id);
-    setDismissedId(current.id);
-  };
-
-  const openCta = () => {
-    if (current.ctaUrl && window.moodmark?.shell?.openUrl) {
-      window.moodmark.shell.openUrl(current.ctaUrl);
-    }
-  };
