-//   { status: 'unauth' }                        → SigninScreen
-//   { status: 'expired', license }              → PaywallModal
-//   { status: 'entitled', license }             → run the app
-//   { status: 'offline', license }              → run the app + banner
-//   { status: 'error', error }                  → SigninScreen + toast
-
