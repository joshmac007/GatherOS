-      state: 'offline',
-      reason: cached.reason,
-      trial_ends_at: cached.trial_ends_at,
-      subscription: cached.subscription,
-      user: cached.user,
-    };
-  }
-  // Cache expired or wasn't entitled to begin with — be strict.
-  return cached.entitled
-    ? { state: 'error' }
-    : cachedToState(cached);
-}
