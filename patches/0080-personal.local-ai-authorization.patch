+    configured: true,
+    ownership: 'user',
+    requiresPro: false,
+  });
+  assert.deepEqual(facade.getAccess().imageGeneration, {
+    capability: 'image-generation',
+    provider: 'gatheros-proxy',
+    configured: false,
+    ownership: 'gatheros',
+    requiresPro: true,
+  });
+});
