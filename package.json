{
  "name": "gatherlocal",
  "productName": "GatherLocal",
  "version": "0.6.0-local.1",
  "description": "A local-first macOS app for saving, browsing, and organizing visual inspiration.",
  "private": true,
  "main": "src/main/index.js",
  "author": {
    "name": "GatherLocal"
  },
  "scripts": {
    "predev": "node scripts/predev.js",
    "dev": "concurrently -k -n vite,electron -c cyan,magenta \"npm:dev:vite\" \"npm:dev:electron\"",
    "dev:vite": "vite",
    "dev:electron": "wait-on http://localhost:5173 && electron .",
    "dev:fresh": "rm -rf .dev-fresh-userdata && concurrently -k -n vite,electron -c cyan,magenta \"npm:dev:vite\" \"wait-on http://localhost:5173 && electron . --user-data-dir=.dev-fresh-userdata\"",
    "build": "vite build && electron-builder",
    "build:renderer": "vite build",
    "build:mac:arm": "vite build && electron-builder --mac --arm64",
    "build:mac:x64": "vite build && electron-builder --mac --x64",
    "prerelease": "node -e \"console.log('GatherLocal public release check skipped: publishing is disabled for local builds.')\"",
    "smoke-test": "node scripts/smoke-test.js",
    "test:ai": "ELECTRON_RUN_AS_NODE=1 electron --test test/*.test.js",
    "pack:extension": "node scripts/pack-extension.js",
    "pack:starter": "ELECTRON_RUN_AS_NODE=1 electron scripts/build-starter-pack.js",
    "release": "rm -rf dist/build && mkdir -p dist && touch dist/.metadata_never_index && vite build && electron-builder --publish never && node scripts/smoke-test.js",
    "ship": "node scripts/ship.js",
    "postrelease": "electron-builder install-app-deps",
    "version:patch": "npm version patch",
    "version:minor": "npm version minor",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.8",
    "@fontsource-variable/geist-mono": "^5.2.7",
    "better-sqlite3": "^12.0.0",
    "electron-updater": "^6.3.9",
    "gifenc": "^1.0.3",
    "node-vibrant": "^4.0.4",
    "sharp": "^0.33.5",
    "yauzl": "^2.10.0"
  },
  "devDependencies": {
    "@electron/notarize": "^2.5.0",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "electron": "^41.0.0",
    "electron-builder": "^24.13.3",
    "lucide-react": "^0.454.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite": "^7.0.0",
    "wait-on": "^7.2.0"
  }
}
