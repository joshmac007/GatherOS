{
  "name": "moodmark",
  "productName": "GatherOS",
  "version": "0.1.21",
  "description": "A local-first macOS app for saving, browsing, and organizing visual inspiration.",
  "private": true,
  "main": "src/main/index.js",
  "author": {
    "name": "GatherOS"
  },
  "scripts": {
    "predev": "node -e \"try{require('child_process').execSync('pkill -f \\\"Electron.app/Contents/MacOS/Electron\\\"',{stdio:'ignore'})}catch(e){}\"",
    "dev": "concurrently -k -n vite,electron -c cyan,magenta \"npm:dev:vite\" \"npm:dev:electron\"",
    "dev:vite": "vite",
    "dev:electron": "wait-on http://localhost:5173 && electron .",
    "build": "vite build && electron-builder",
    "build:renderer": "vite build",
    "build:mac:arm": "vite build && electron-builder --mac --arm64",
    "build:mac:x64": "vite build && electron-builder --mac --x64",
    "prerelease": "node scripts/check-release-version.js",
    "release": "vite build && electron-builder --publish always",
    "postrelease": "electron-builder install-app-deps",
    "version:patch": "npm version patch",
    "version:minor": "npm version minor",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "better-sqlite3": "^12.0.0",
    "electron-updater": "^6.3.9",
    "node-vibrant": "^4.0.4",
    "sharp": "^0.33.5"
  },
  "devDependencies": {
    "@electron/notarize": "^2.5.0",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "electron": "^41.0.0",
    "electron-builder": "^24.13.3",
    "lucide-react": "^0.454.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite": "^7.0.0",
    "wait-on": "^7.2.0"
  }
}
